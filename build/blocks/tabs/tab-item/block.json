{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rcb/tab-item",
  "version": "1.0.0",
  "title": "Tab Item (RCB)",
  "category": "rcb-components",
  "parent": [
    "rcb/tabs"
  ],
  "attributes": {
    "label": {
      "type": "string",
      "default": "New Tab"
    },
    "icon": {
      "type": "string"
    },
    "tabId": {
      "type": "string"
    }
  },
  "supports": {
    "html": false,
    "reusable": false,
    "color": {
      "text": true,
      "background": true
    },
    "spacing": {
      "padding": true,
      "margin": true
    }
  },
  "textdomain": "reusable-component-builder",
  "usesContext": [
    "rcb/activeTabClientId"
  ],
  "editorScript": "file:./index.js"
}