{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "rcb/slide-item",
    "version": "1.0.0",
    "title": "Slide Item (RCB)",
    "category": "rcb-components",
    "parent": [ "rcb/slider" ],
    "attributes": {
        "mediaId": { "type": "number" },
        "mediaUrl": { "type": "string" },
        "bgType": { "type": "string", "default": "image" },
        "bgColor": { "type": "string", "default": "#3b82f6" },
        "showAvatar": { "type": "boolean", "default": false },
        "avatarId": { "type": "number" },
        "avatarUrl": { "type": "string" },
        "avatarSize": { "type": "number", "default": 80 },
        "avatarBorderRadius": { "type": "number", "default": 50 },
        "showRating": { "type": "boolean", "default": false },
        "rating": { "type": "number", "default": 5 },
        "ratingColor": { "type": "string", "default": "#facc15" },
        "verticalAlignment": { "type": "string", "default": "center" },
        "showContentBg": { "type": "boolean", "default": false },
        "contentBgColor": { "type": "string", "default": "rgba(0,0,0,0.5)" },
        "contentPadding": { "type": "number", "default": 40 },
        "contentBorderRadius": { "type": "number", "default": 8 },
        "caption": { "type": "string", "default": "" },
        "showTitle": { "type": "boolean", "default": true },
        "title": { "type": "string", "default": "Slide Title" },
        "titleColor": { "type": "string", "default": "#ffffff" },
        "titleFontSize": { "type": "number", "default": 40 },
        "titleFontWeight": { "type": "string", "default": "700" },
        "showDesc": { "type": "boolean", "default": true },
        "description": { "type": "string", "default": "Slide description text goes here." },
        "descColor": { "type": "string", "default": "#eeeeee" },
        "descFontSize": { "type": "number", "default": 18 },
        "descFontWeight": { "type": "string", "default": "400" },
        "showBtn": { "type": "boolean", "default": true },
        "btnText": { "type": "string", "default": "Learn More" },
        "btnLink": { "type": "string", "default": "#" },
        "btnColor": { "type": "string", "default": "#ffffff" },
        "btnBgColor": { "type": "string", "default": "#3b82f6" },
        "btnBorderRadius": { "type": "number", "default": 4 },
        "btnFontSize": { "type": "number", "default": 16 },
        "overlayOpacity": { "type": "number", "default": 0.3 },
        "overlayColor": { "type": "string", "default": "#000000" },
        "contentAlignment": { "type": "string", "default": "center" }
    },
    "supports": {
        "html": false,
        "reusable": false,
        "color": {
            "text": true
        }
    },
    "textdomain": "reusable-component-builder",
    "editorScript": "file:./index.js"
}
